# ============================================================
# WebSecCheck — environment variable template
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to version control.
# ============================================================


# ------------------------------------------------------------
# Core Flask settings
# ------------------------------------------------------------

# Long random string used for session signing and CSRF protection.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-secret-key

# One of: development | testing | production
FLASK_ENV=production


# ------------------------------------------------------------
# Database
# ------------------------------------------------------------

# SQLite (default — suitable for single-server deployments):
DATABASE_URL=sqlite:///webseccheck.db

# PostgreSQL example (recommended for production):
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/webseccheck


# ------------------------------------------------------------
# Redis (Celery broker + result backend + rate limiter)
# ------------------------------------------------------------

REDIS_URL=redis://localhost:6379/0


# ------------------------------------------------------------
# Mail (SMTP)
# ------------------------------------------------------------

MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-smtp-username
MAIL_PASSWORD=your-smtp-password
MAIL_DEFAULT_SENDER=noreply@example.com


# ------------------------------------------------------------
# Application
# ------------------------------------------------------------

# The public domain name of the application (used for email links, CSP, etc.)
APP_DOMAIN=example.com

# Comma-separated list of allowed Host header values.
# Include your domain and any reverse-proxy addresses.
ALLOWED_HOSTS=example.com,www.example.com

# Email address that receives admin notifications (scan errors, etc.)
ADMIN_EMAIL=admin@example.com


# ------------------------------------------------------------
# Optional overrides
# ------------------------------------------------------------

# Logging verbosity: DEBUG | INFO | WARNING | ERROR | CRITICAL
# LOG_LEVEL=INFO
